# Environment variables for local development
# Copy to .env and fill in real values

# PostgreSQL
POSTGRES_USER=intent
POSTGRES_PASSWORD=intent_dev_password
POSTGRES_DB=intent_commerce
DATABASE_URL=postgresql+asyncpg://intent:intent_dev_password@localhost:5432/intent_commerce

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenAI / LLM
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-your-anthropic-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Security
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# S3 / Image Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=intent-commerce-images
